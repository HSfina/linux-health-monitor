[Unit]
Description=Linux Health Monitor Service
After=network.target

[Service]
Type=simple
User=soufiane
ExecStart=/bin/bash /home/soufiane/linux-health-monitor/monitor_service.sh
Restart=always
RestartSec=10
StandardOutput=append:/home/soufiane/linux-health-monitor/service.log
StandardError=append:/home/soufiane/linux-health-monitor/service_error.log

[Install]
WantedBy=multi-user.target
